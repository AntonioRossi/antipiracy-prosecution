{
 "schemaVersion": "1",
 "comment": "Closed schema for declarative corpus segmentation profiles. First matching rule wins; unmatched input is excluded.",
 "type": "object",
 "required": ["profileVersion", "corpusId", "comment", "rules"],
 "additionalProperties": false,
 "properties": {
  "profileVersion": {"type": "string", "enum": ["1"]},
  "corpusId": {"type": "string", "minLength": 1},
  "claimsHeading": {"type": "string", "minLength": 1},
  "pctClaimsSection": {
   "type": "array",
   "minItems": 1,
   "items": {"type": "string", "minLength": 1}
  },
  "comment": {"type": "string", "minLength": 1},
  "rules": {
   "type": "array",
   "minItems": 1,
   "items": {
    "type": "object",
    "required": ["match", "class"],
    "additionalProperties": false,
    "properties": {
     "match": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
       "kind": {
        "type": "string",
        "enum": ["heading", "code", "blockquote", "table", "image", "bullet", "ordered", "footer", "claimhead", "paragraph"]
       },
       "path": {
        "type": "array",
        "minItems": 1,
        "items": {"type": "string", "minLength": 1}
       }
      }
     },
     "class": {
      "type": "string",
      "enum": ["targetable", "editorial", "quotable", "excluded", "claims"]
     },
     "editorialLabel": {"type": "string", "minLength": 1}
    }
   }
  }
 }
}
