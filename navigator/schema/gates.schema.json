{
 "schemaVersion": "1",
 "comment": "Closed schema for gate inventories (TDD §8.1). appliesTo carries hashed endpoints per requiredScope: claim scope -> claims with aggregate claim hashes; fragment scope -> fragments with fragment hashes; target scope -> fragments with hashes plus a required cardinality. Scope-shape conformity and hash currency are checked by the validator (invariants + model).",
 "type": "object",
 "required": ["inventoryVersion", "corpusId", "profileDigest", "gates"],
 "additionalProperties": false,
 "properties": {
  "inventoryVersion": {"type": "string", "enum": ["1"]},
  "corpusId": {"type": "string", "minLength": 1},
  "profileDigest": {"type": "string", "minLength": 1},
  "comment": {"type": "string"},
  "gates": {
   "type": "array",
   "minItems": 1,
   "items": {
    "type": "object",
    "required": ["gateId", "code", "requiredScope", "requirement", "source", "appliesTo"],
    "additionalProperties": false,
    "properties": {
     "gateId": {"type": "string", "minLength": 1},
     "code": {"type": "string", "minLength": 1},
     "requiredScope": {"type": "string", "enum": ["target", "fragment", "claim"]},
     "requirement": {"type": "string", "enum": ["mandatory", "optional"]},
     "source": {
      "type": "object",
      "required": ["block", "textHash"],
      "additionalProperties": false,
      "properties": {
       "block": {"type": "string", "minLength": 1},
       "textHash": {"type": "string", "minLength": 1}
      }
     },
     "appliesTo": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
       "claims": {
        "type": "array",
        "minItems": 1,
        "items": {
         "type": "object",
         "required": ["claim", "claimHash"],
         "additionalProperties": false,
         "properties": {
          "claim": {"type": "integer"},
          "claimHash": {"type": "string", "minLength": 1}
         }
        }
       },
       "fragments": {
        "type": "array",
        "minItems": 1,
        "items": {
         "type": "object",
         "required": ["id", "hash"],
         "additionalProperties": false,
         "properties": {
          "id": {"type": "string", "minLength": 1},
          "hash": {"type": "string", "minLength": 1}
         }
        }
       },
       "cardinality": {
        "type": "object",
        "required": ["minTargetsPerFragment"],
        "additionalProperties": false,
        "properties": {
         "minTargetsPerFragment": {"type": "integer", "minimum": 1}
        }
       }
      }
     }
    }
   }
  }
 }
}
